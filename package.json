{
  "name": "meta-harness-studio",
  "version": "0.1.0",
  "description": "Author one harness, project it onto Claude Code, Codex, OpenCode, Cline, Kilo Code and Pi — then close the loop and let an agentic proposer improve it from execution traces.",
  "type": "module",
  "license": "MIT",
  "author": "Pragnesh (fugitivexyz)",
  "homepage": "https://github.com/engn-dev/meta-harness-studio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engn-dev/meta-harness-studio.git"
  },
  "bugs": {
    "url": "https://github.com/engn-dev/meta-harness-studio/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "harness",
    "claude-code",
    "codex",
    "opencode",
    "cline",
    "kilo-code",
    "pi",
    "agents.md",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "harness": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "harness": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.0.1",
    "smol-toml": "^1.3.0",
    "tinyglobby": "^0.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
